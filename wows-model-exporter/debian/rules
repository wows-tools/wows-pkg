#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_configure:
	dh_auto_configure -- -DCMAKE_BUILD_TYPE=Release

override_dh_auto_install:
	dh_auto_install
	install -Dm644 inc/wows-model-exporter.h \
		$(CURDIR)/debian/libwows-geometry-dev/usr/include/wows-model-exporter.h
	install -Dm644 inc/wows-game-params.h \
		$(CURDIR)/debian/libwows-geometry-dev/usr/include/wows-game-params.h
	install -Dm644 inc/wows-assets-bin.h \
		$(CURDIR)/debian/libwows-geometry-dev/usr/include/wows-assets-bin.h

override_dh_auto_clean:
	dh_auto_clean
	rm -rf build

override_dh_shlibdeps:
	dh_shlibdeps --dpkg-shlibdeps-params=--ignore-missing-info
