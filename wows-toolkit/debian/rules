#!/usr/bin/make -f

export RUSTUP_HOME=/tmp/rustup
export CARGO_HOME=/tmp/cargo_home
export CARGO_TARGET_DIR=/tmp/cargo
export CARGO_TARGET_TMPDIR=/tmp/cargo/tmp
# Limit parallelism and disable LTO to avoid OOM during release builds
export CARGO_BUILD_JOBS=1
export CARGO_PROFILE_RELEASE_LTO=false

%:
	dh $@

override_dh_auto_clean:
	mkdir -p $(CARGO_TARGET_DIR) $(CARGO_TARGET_TMPDIR) $(CARGO_HOME)
	rustup default stable
	dh_auto_clean

override_dh_auto_configure:
	cargo fetch

override_dh_auto_build:
	cargo build --release

override_dh_auto_install:
	install -Dm755 $(CARGO_TARGET_DIR)/release/wows_toolkit  $(CURDIR)/debian/wows-toolkit/usr/bin/wows_toolkit
	install -Dm755 $(CARGO_TARGET_DIR)/release/wowsunpack    $(CURDIR)/debian/wows-toolkit/usr/bin/wowsunpack
	install -Dm755 $(CARGO_TARGET_DIR)/release/replayshark   $(CURDIR)/debian/wows-toolkit/usr/bin/replayshark
	install -Dm644 assets/wows-toolkit.desktop               $(CURDIR)/debian/wows-toolkit/usr/share/applications/wows-toolkit.desktop
	install -Dm644 assets/wows_toolkit.png                   $(CURDIR)/debian/wows-toolkit/usr/share/icons/hicolor/256x256/apps/io.github.landaire.WoWsToolkit.png

override_dh_auto_test:

override_dh_shlibdeps:
	dh_shlibdeps --dpkg-shlibdeps-params=--ignore-missing-info
